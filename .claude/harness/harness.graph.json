{
  "version": 1,
  "nodes": [
    {"id": "phase-context", "type": "workflow_phase", "label": "Context, graph, audit, and cleanup check", "phase": "0"},
    {"id": "phase-routing", "type": "workflow_phase", "label": "Routing decision", "phase": "1"},
    {"id": "phase-planning", "type": "workflow_phase", "label": "Execution plan report", "phase": "2"},
    {"id": "phase-execution", "type": "workflow_phase", "label": "Upper-tier agent execution", "phase": "3"},
    {"id": "phase-quality", "type": "workflow_phase", "label": "Test, optimize, and deploy gate", "phase": "3.5-4"},
    {"id": "phase-feedback", "type": "workflow_phase", "label": "Result delivery and feedback capture", "phase": "5"},

    {"id": "personal-assistant", "type": "skill", "label": "Personal Assistant orchestrator", "path": ".claude/skills/personal-assistant/SKILL.md", "purpose": "Route requests through the local Claude Code harness"},

    {"id": "router-agent", "type": "agent", "label": "Router Agent", "path": ".claude/agents/router-agent.md", "model": "sonnet", "phase": "routing"},
    {"id": "planner-agent", "type": "agent", "label": "Planner Agent", "path": ".claude/agents/planner-agent.md", "model": "opus", "phase": "planning"},
    {"id": "dev-agent", "type": "agent", "label": "Development Agent", "path": ".claude/agents/dev-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "frontend-agent", "type": "agent", "label": "Frontend Agent", "path": ".claude/agents/frontend-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "backend-agent", "type": "agent", "label": "Backend Agent", "path": ".claude/agents/backend-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "api-agent", "type": "agent", "label": "API Agent", "path": ".claude/agents/api-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "content-agent", "type": "agent", "label": "Content Agent", "path": ".claude/agents/content-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "data-agent", "type": "agent", "label": "Data Agent", "path": ".claude/agents/data-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "design-agent", "type": "agent", "label": "Design Agent", "path": ".claude/agents/design-agent.md", "model": "opus", "phase": "upper-tier"},
    {"id": "security-agent", "type": "agent", "label": "Security Agent", "path": ".claude/agents/security-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "github-agent", "type": "agent", "label": "GitHub Agent", "path": ".claude/agents/github-agent.md", "model": "sonnet", "phase": "upper-tier"},
    {"id": "research-agent", "type": "agent", "label": "Research Agent", "path": ".claude/agents/research-agent.md", "model": "sonnet", "phase": "sub-agent"},
    {"id": "test-agent", "type": "agent", "label": "Test Agent", "path": ".claude/agents/test-agent.md", "model": "sonnet", "phase": "post-processing"},
    {"id": "optimizer-agent", "type": "agent", "label": "Optimizer Agent", "path": ".claude/agents/optimizer-agent.md", "model": "opus", "phase": "post-processing"},
    {"id": "deploy-agent", "type": "agent", "label": "Deploy Agent", "path": ".claude/agents/deploy-agent.md", "model": "sonnet", "phase": "post-processing"},

    {"id": "plugin-harness", "type": "plugin", "label": "harness@harness-marketplace", "purpose": "Harness construction and maintenance", "weight": "medium", "required_by": ["personal-assistant"], "cleanup_policy": "keep"},
    {"id": "plugin-skill-creator", "type": "plugin", "label": "skill-creator@claude-plugins-official", "purpose": "Skill creation and editing", "weight": "medium", "required_by": ["personal-assistant"], "cleanup_policy": "keep"},
    {"id": "plugin-firecrawl", "type": "plugin", "label": "firecrawl@claude-plugins-official", "purpose": "Research web search and scraping", "weight": "medium", "required_by": ["research-agent"], "cleanup_policy": "conditional_keep"},
    {"id": "plugin-figma", "type": "plugin", "label": "figma@claude-plugins-official", "purpose": "Design and Figma workflows", "weight": "heavy", "required_by": ["design-agent"], "cleanup_policy": "conditional_keep"},
    {"id": "plugin-vercel", "type": "plugin", "label": "vercel@claude-plugins-official", "purpose": "Vercel deployment workflows", "weight": "medium", "required_by": ["deploy-agent"], "cleanup_policy": "conditional_keep"},
    {"id": "plugin-csv-analyze", "type": "plugin", "label": "csv-analyze@my-skills", "purpose": "CSV and spreadsheet analysis", "weight": "light", "required_by": ["data-agent"], "cleanup_policy": "conditional_keep"},
    {"id": "plugin-superpowers", "type": "plugin", "label": "superpowers@claude-plugins-official", "purpose": "Optional development methodology skills", "weight": "heavy", "required_by": [], "cleanup_policy": "disabled"},
    {"id": "plugin-understand-anything", "type": "plugin", "label": "understand-anything@understand-anything", "purpose": "Optional repository understanding cache", "weight": "heavy", "required_by": [], "cleanup_policy": "disabled"},
    {"id": "plugin-karpathy-skills", "type": "plugin", "label": "andrej-karpathy-skills@karpathy-skills", "purpose": "Optional learning/reference skills", "weight": "medium", "required_by": [], "cleanup_policy": "disabled"},

    {"id": "proc-subagent", "type": "process_type", "label": "Subagent", "description": "Coordinator routes to specialist agents; results are combined into a single answer", "maps_to_phases": ["phase-routing", "phase-execution"]},
    {"id": "proc-batch", "type": "process_type", "label": "Batch", "description": "Independent task list dispatched to agents in parallel; results collected separately", "maps_to_phases": ["phase-execution"]},
    {"id": "proc-deep-research", "type": "process_type", "label": "Deep Research", "description": "Plan / search / verify loop using research-agent + firecrawl; outputs a report", "maps_to_phases": ["phase-execution"]},
    {"id": "proc-goal", "type": "process_type", "label": "Goal", "description": "Plan → build → review → refine → complete loop spanning all phases including deploy", "maps_to_phases": ["phase-context", "phase-routing", "phase-planning", "phase-execution", "phase-quality", "phase-feedback"]}
  ],
  "edges": [
    {"from": "phase-context", "to": "personal-assistant", "type": "requires"},
    {"from": "personal-assistant", "to": "router-agent", "type": "routes"},
    {"from": "router-agent", "to": "planner-agent", "type": "routes"},
    {"from": "planner-agent", "to": "phase-execution", "type": "routes"},
    {"from": "phase-execution", "to": "dev-agent", "type": "routes", "condition": "general development"},
    {"from": "phase-execution", "to": "frontend-agent", "type": "routes", "condition": "frontend work"},
    {"from": "phase-execution", "to": "backend-agent", "type": "routes", "condition": "backend work"},
    {"from": "phase-execution", "to": "api-agent", "type": "routes", "condition": "API contract work"},
    {"from": "phase-execution", "to": "content-agent", "type": "routes", "condition": "content work"},
    {"from": "phase-execution", "to": "data-agent", "type": "routes", "condition": "data work"},
    {"from": "phase-execution", "to": "design-agent", "type": "routes", "condition": "design work"},
    {"from": "phase-execution", "to": "security-agent", "type": "routes", "condition": "security work"},
    {"from": "phase-execution", "to": "github-agent", "type": "routes", "condition": "git or GitHub work"},
    {"from": "design-agent", "to": "research-agent", "type": "depends_on", "condition": "design references are required"},
    {"from": "content-agent", "to": "research-agent", "type": "depends_on", "condition": "fresh facts are required"},
    {"from": "phase-execution", "to": "test-agent", "type": "post_processes"},
    {"from": "test-agent", "to": "optimizer-agent", "type": "post_processes", "condition": "Phase B passes and output is optimizable"},
    {"from": "optimizer-agent", "to": "deploy-agent", "type": "post_processes", "condition": "deployable output exists"},
    {"from": "proc-subagent", "to": "phase-execution", "type": "uses", "condition": "multi-specialist coordination"},
    {"from": "proc-batch", "to": "phase-execution", "type": "uses", "condition": "independent parallel tasks"},
    {"from": "proc-deep-research", "to": "research-agent", "type": "uses", "condition": "research + verify loop"},
    {"from": "proc-deep-research", "to": "plugin-firecrawl", "type": "uses", "condition": "web search required"},
    {"from": "proc-goal", "to": "personal-assistant", "type": "uses", "condition": "full plan-build-deploy loop"},
    {"from": "phase-feedback", "to": "personal-assistant", "type": "feedback_updates"},
    {"from": "phase-context", "to": "plugin-superpowers", "type": "cleanup_reviews"},
    {"from": "phase-context", "to": "plugin-understand-anything", "type": "cleanup_reviews"},
    {"from": "phase-context", "to": "plugin-karpathy-skills", "type": "cleanup_reviews"}
  ]
}
